# TradingView EUR/USD Monitor Configuration

# TradingView symbol (default: FX:EURUSD)
SYMBOL=FX:EURUSD

# Summary report interval in milliseconds (default: 300000 = 5 minutes)
SUMMARY_INTERVAL=300000

# Price change threshold for alerts in price units (default: 0.0010 = 10 pips)
PRICE_THRESHOLD=0.0010

# Telegram Bot Token (optional - get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (optional - your user/group chat ID)
TELEGRAM_CHAT_ID=
